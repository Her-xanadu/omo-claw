{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "compatibility/**/*.ts",
    "definitions/**/*.ts",
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}
